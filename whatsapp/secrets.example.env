# Шаблон секретов WhatsApp Cloud API.
# 1) Скопируйте этот файл рядом под именем  secrets.env
# 2) Заполните значения (см. whatsapp/README.md — там пошагово, что где брать в Meta)
# secrets.env в .gitignore — в git не попадёт.

# Любая строка, которую вы сами придумаете. Её же введёте в Meta при настройке вебхука.
WHATSAPP_VERIFY_TOKEN=aucopy-verify-change-me

# Meta → ваше приложение → WhatsApp → API Setup:
#   "Temporary access token" (на старте; живёт 24 часа) либо постоянный токен System User
WHATSAPP_ACCESS_TOKEN=
#   "Phone number ID" (НЕ сам номер телефона, а его ID рядом в том же окне)
WHATSAPP_PHONE_NUMBER_ID=

# Meta → App settings → Basic → "App secret".
# Нужен для проверки подписи вебхука. На старте можно оставить пустым (проверка отключится).
WHATSAPP_APP_SECRET=

# Обычно менять не нужно:
WHATSAPP_API_VERSION=v21.0
BACKEND_URL=http://127.0.0.1:8000
UPLOAD_TOKEN=dev-secret-change-me
WHATSAPP_PORT=8001
